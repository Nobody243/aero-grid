# Copy this to .env for local backend development
ENVIRONMENT=development

# Comma-separated list of allowed CORS origins
# Development default (no restriction on rate limiting)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Production (set these in the Render dashboard, not here)
# ENVIRONMENT=production
# ALLOWED_ORIGINS=https://aerogrid-simulator-ag24303.vercel.app
